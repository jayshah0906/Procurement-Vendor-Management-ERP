generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model activity_logs {
  id              BigInt         @id @default(autoincrement())
  organization_id String?        @db.Uuid
  actor_user_id   String?        @db.Uuid
  ip_address      String?        @db.VarChar(45)
  entity_type     String         @db.VarChar(50)
  entity_id       String?        @db.Uuid
  action          String         @db.VarChar(100)
  old_value       Json?
  new_value       Json?
  created_at      DateTime?      @default(now()) @db.Timestamptz(6)
  users           users?         @relation(fields: [actor_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organizations   organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([entity_type, entity_id], map: "idx_logs_entity")
  @@index([organization_id, created_at(sort: Desc)], map: "idx_logs_org_created")
}

model api_keys {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String?        @db.Uuid
  name            String         @db.VarChar(100)
  key_hash        String
  expires_at      DateTime?      @db.Timestamptz(6)
  created_at      DateTime?      @default(now()) @db.Timestamptz(6)
  deleted_at      DateTime?      @db.Timestamptz(6)
  organizations   organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model approval_steps {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflow_id        String?             @db.Uuid
  approver_id        String              @db.Uuid
  level_no           Int
  status             approval_status?    @default(pending)
  remarks            String?
  action_at          DateTime?           @db.Timestamptz(6)
  deleted_at         DateTime?           @db.Timestamptz(6)
  users              users               @relation(fields: [approver_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approval_workflows approval_workflows? @relation(fields: [workflow_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([workflow_id, level_no])
}

model approval_workflows {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String?          @db.Uuid
  entity_type     String           @db.VarChar(50)
  entity_id       String           @db.Uuid
  initiated_by    String?          @db.Uuid
  current_level   Int?             @default(1)
  status          approval_status? @default(pending)
  created_at      DateTime?        @default(now()) @db.Timestamptz(6)
  deleted_at      DateTime?        @db.Timestamptz(6)
  approval_steps  approval_steps[]
  users           users?           @relation(fields: [initiated_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organizations   organizations?   @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([entity_type, entity_id])
}

model attachments {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String?        @db.Uuid
  entity_type     String         @db.VarChar(50)
  entity_id       String         @db.Uuid
  file_name       String
  file_url        String
  file_size_bytes BigInt?
  mime_type       String?        @db.VarChar(100)
  uploaded_by     String?        @db.Uuid
  uploaded_at     DateTime?      @default(now()) @db.Timestamptz(6)
  deleted_at      DateTime?      @db.Timestamptz(6)
  organizations   organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users           users?         @relation(fields: [uploaded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model comments {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String?        @db.Uuid
  entity_type     String         @db.VarChar(50)
  entity_id       String         @db.Uuid
  user_id         String?        @db.Uuid
  comment         String
  created_at      DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?      @default(now()) @db.Timestamptz(6)
  deleted_at      DateTime?      @db.Timestamptz(6)
  organizations   organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users           users?         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model document_sequences {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String?        @db.Uuid
  document_type   String         @db.VarChar(50)
  prefix          String         @db.VarChar(20)
  next_value      BigInt?        @default(1000)
  created_at      DateTime?      @default(now()) @db.Timestamptz(6)
  organizations   organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([organization_id, document_type])
}

model invoice_email_logs {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoice_id      String?   @db.Uuid
  recipient_email String
  sent_at         DateTime? @default(now()) @db.Timestamptz(6)
  status          String?   @default("sent") @db.VarChar(50)
  error_message   String?
  invoices        invoices? @relation(fields: [invoice_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model invoices {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id    String?              @db.Uuid
  invoice_number     String               @db.VarChar(50)
  purchase_order_id  String?              @db.Uuid
  vendor_id          String?              @db.Uuid
  subtotal           Decimal?             @db.Decimal(15, 2)
  cgst               Decimal?             @db.Decimal(15, 2)
  sgst               Decimal?             @db.Decimal(15, 2)
  igst               Decimal?             @db.Decimal(15, 2)
  grand_total        Decimal              @db.Decimal(15, 2)
  pdf_url            String?
  status             invoice_status?      @default(pending)
  invoice_date       DateTime             @db.Date
  due_date           DateTime             @db.Date
  sent_at            DateTime?            @db.Timestamptz(6)
  paid_at            DateTime?            @db.Timestamptz(6)
  created_at         DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?            @default(now()) @db.Timestamptz(6)
  deleted_at         DateTime?            @db.Timestamptz(6)
  invoice_email_logs invoice_email_logs[]
  organizations      organizations?       @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purchase_orders    purchase_orders?     @relation(fields: [purchase_order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendors            vendors?             @relation(fields: [vendor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([organization_id, invoice_number])
}

model notifications {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String?   @db.Uuid
  title               String    @db.VarChar(255)
  message             String
  is_read             Boolean?  @default(false)
  related_entity_type String?   @db.VarChar(50)
  related_entity_id   String?   @db.Uuid
  created_at          DateTime? @default(now()) @db.Timestamptz(6)
  users               users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model organization_settings {
  organization_id   String        @id @db.Uuid
  currency          String?       @default("INR") @db.VarChar(10)
  tax_percentage    Decimal?      @default(18.00) @db.Decimal(5, 2)
  po_terms_template String?
  updated_at        DateTime?     @default(now()) @db.Timestamptz(6)
  organizations     organizations @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model organizations {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                   String                   @db.VarChar(255)
  gst_number             String?                  @unique @db.VarChar(50)
  email                  String?                  @db.VarChar(255)
  phone                  String?                  @db.VarChar(30)
  address                String?
  timezone               String?                  @default("UTC") @db.VarChar(50)
  created_at             DateTime?                @default(now()) @db.Timestamptz(6)
  updated_at             DateTime?                @default(now()) @db.Timestamptz(6)
  deleted_at             DateTime?                @db.Timestamptz(6)
  activity_logs          activity_logs[]
  api_keys               api_keys[]
  approval_workflows     approval_workflows[]
  attachments            attachments[]
  comments               comments[]
  document_sequences     document_sequences[]
  invoices               invoices[]
  organization_settings  organization_settings?
  procurement_categories procurement_categories[]
  purchase_orders        purchase_orders[]
  quotations             quotations[]
  rfqs                   rfqs[]
  users                  users[]
  vendors                vendors[]
  webhook_endpoints      webhook_endpoints[]
}

model permissions {
  id               Int                @id @default(autoincrement())
  resource         String             @db.VarChar(50)
  action           String             @db.VarChar(50)
  role_permissions role_permissions[]

  @@unique([resource, action])
}

model procurement_categories {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id      String?                @db.Uuid
  name                 String                 @db.VarChar(100)
  description          String?
  created_at           DateTime?              @default(now()) @db.Timestamptz(6)
  deleted_at           DateTime?              @db.Timestamptz(6)
  organizations        organizations?         @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purchase_order_items purchase_order_items[]
  rfqs                 rfqs[]
  vendors              vendors[]

  @@unique([organization_id, name])
}

model purchase_order_items {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchase_order_id      String?                 @db.Uuid
  category_id            String?                 @db.Uuid
  item_name              String                  @db.VarChar(255)
  quantity               Decimal                 @db.Decimal(12, 2)
  unit_price             Decimal                 @db.Decimal(15, 2)
  total_price            Decimal                 @db.Decimal(15, 2)
  received_quantity      Decimal?                @default(0) @db.Decimal(12, 2)
  deleted_at             DateTime?               @db.Timestamptz(6)
  procurement_categories procurement_categories? @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purchase_orders        purchase_orders?        @relation(fields: [purchase_order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model purchase_orders {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id      String?                @db.Uuid
  po_number            String                 @db.VarChar(50)
  quotation_id         String?                @db.Uuid
  vendor_id            String?                @db.Uuid
  subtotal             Decimal                @db.Decimal(15, 2)
  tax_amount           Decimal                @db.Decimal(15, 2)
  total_amount         Decimal                @db.Decimal(15, 2)
  status               po_status?             @default(generated)
  delivery_date        DateTime?              @db.Date
  shipping_address     String?
  billing_address      String?
  terms                String?
  generated_by         String?                @db.Uuid
  created_at           DateTime?              @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?              @default(now()) @db.Timestamptz(6)
  deleted_at           DateTime?              @db.Timestamptz(6)
  invoices             invoices[]
  purchase_order_items purchase_order_items[]
  users                users?                 @relation(fields: [generated_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organizations        organizations?         @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  quotations           quotations?            @relation(fields: [quotation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendors              vendors?               @relation(fields: [vendor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([organization_id, po_number])
}

model quotation_items {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quotation_id  String?     @db.Uuid
  rfq_item_id   String?     @db.Uuid
  item_name     String      @db.VarChar(255)
  quantity      Decimal     @db.Decimal(12, 2)
  unit_price    Decimal     @db.Decimal(15, 2)
  total_price   Decimal     @db.Decimal(15, 2)
  delivery_days Int?
  deleted_at    DateTime?   @db.Timestamptz(6)
  quotations    quotations? @relation(fields: [quotation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rfq_items     rfq_items?  @relation(fields: [rfq_item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model quotation_revisions {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quotation_id String?     @db.Uuid
  revision_no  Int
  snapshot     Json
  created_by   String?     @db.Uuid
  created_at   DateTime?   @default(now()) @db.Timestamptz(6)
  users        users?      @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  quotations   quotations? @relation(fields: [quotation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model quotations {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id     String?               @db.Uuid
  quotation_number    String                @db.VarChar(50)
  rfq_id              String?               @db.Uuid
  vendor_id           String?               @db.Uuid
  subtotal            Decimal               @db.Decimal(15, 2)
  tax_amount          Decimal               @db.Decimal(15, 2)
  grand_total         Decimal               @db.Decimal(15, 2)
  delivery_days       Int?
  valid_until         DateTime?             @db.Timestamptz(6)
  notes               String?
  status              quotation_status?     @default(submitted)
  submitted_at        DateTime?             @db.Timestamptz(6)
  created_by          String?               @db.Uuid
  created_at          DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?             @default(now()) @db.Timestamptz(6)
  deleted_at          DateTime?             @db.Timestamptz(6)
  purchase_orders     purchase_orders[]
  quotation_items     quotation_items[]
  quotation_revisions quotation_revisions[]
  users               users?                @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organizations       organizations?        @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rfqs                rfqs?                 @relation(fields: [rfq_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendors             vendors?              @relation(fields: [vendor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([organization_id, quotation_number])
}

model rfq_items {
  id                   String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rfq_id               String?           @db.Uuid
  item_name            String            @db.VarChar(255)
  description          String?
  quantity             Decimal           @db.Decimal(12, 2)
  unit                 String?           @default("NOS") @db.VarChar(50)
  estimated_unit_price Decimal?          @db.Decimal(15, 2)
  deleted_at           DateTime?         @db.Timestamptz(6)
  quotation_items      quotation_items[]
  rfqs                 rfqs?             @relation(fields: [rfq_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model rfq_revisions {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rfq_id     String?   @db.Uuid
  version_no Int
  snapshot   Json
  created_by String?   @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users?    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rfqs       rfqs?     @relation(fields: [rfq_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model rfq_vendors {
  rfq_id       String    @db.Uuid
  vendor_id    String    @db.Uuid
  invited_at   DateTime? @default(now()) @db.Timestamptz(6)
  responded_at DateTime? @db.Timestamptz(6)
  deleted_at   DateTime? @db.Timestamptz(6)
  rfqs         rfqs      @relation(fields: [rfq_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendors      vendors   @relation(fields: [vendor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([rfq_id, vendor_id])
}

model rfqs {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id        String?                 @db.Uuid
  rfq_number             String                  @db.VarChar(50)
  category_id            String?                 @db.Uuid
  title                  String                  @db.VarChar(255)
  description            String?
  deadline               DateTime                @db.Timestamptz(6)
  status                 rfq_status?             @default(draft)
  currency               String?                 @default("INR") @db.VarChar(10)
  total_estimated_amount Decimal?                @db.Decimal(15, 2)
  created_by             String                  @db.Uuid
  created_at             DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at             DateTime?               @default(now()) @db.Timestamptz(6)
  deleted_at             DateTime?               @db.Timestamptz(6)
  quotations             quotations[]
  rfq_items              rfq_items[]
  rfq_revisions          rfq_revisions[]
  rfq_vendors            rfq_vendors[]
  procurement_categories procurement_categories? @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                  users                   @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organizations          organizations?          @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([organization_id, rfq_number])
}

model role_permissions {
  role_id       Int
  permission_id Int
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([role_id, permission_id])
}

model roles {
  id               Int                @id @default(autoincrement())
  name             String             @unique @db.VarChar(50)
  description      String?            @db.VarChar(255)
  role_permissions role_permissions[]
  users            users[]
}

model users {
  id                                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id                   String?               @db.Uuid
  role_id                           Int
  vendor_id                         String?               @db.Uuid
  first_name                        String                @db.VarChar(100)
  last_name                         String?               @db.VarChar(100)
  email                             String                @unique @db.VarChar(255)
  password_hash                     String
  phone                             String?               @db.VarChar(30)
  mfa_enabled                       Boolean?              @default(false)
  last_login                        DateTime?             @db.Timestamptz(6)
  is_active                         Boolean?              @default(true)
  created_at                        DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at                        DateTime?             @default(now()) @db.Timestamptz(6)
  deleted_at                        DateTime?             @db.Timestamptz(6)
  activity_logs                     activity_logs[]
  approval_steps                    approval_steps[]
  approval_workflows                approval_workflows[]
  attachments                       attachments[]
  comments                          comments[]
  notifications                     notifications[]
  purchase_orders                   purchase_orders[]
  quotation_revisions               quotation_revisions[]
  quotations                        quotations[]
  rfq_revisions                     rfq_revisions[]
  rfqs                              rfqs[]
  vendors_users_vendor_idTovendors  vendors?              @relation("users_vendor_idTovendors", fields: [vendor_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_vendor")
  organizations                     organizations?        @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  roles                             roles                 @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendors_vendors_created_byTousers vendors[]             @relation("vendors_created_byTousers")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model vendors {
  id                              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id                 String?                 @db.Uuid
  category_id                     String?                 @db.Uuid
  company_name                    String                  @db.VarChar(255)
  gst_number                      String?                 @db.VarChar(50)
  contact_person                  String?                 @db.VarChar(255)
  email                           String                  @db.VarChar(255)
  phone                           String?                 @db.VarChar(30)
  address                         String?
  status                          vendor_status?          @default(pending)
  rating                          Decimal?                @db.Decimal(2, 1)
  onboarding_completed            Boolean?                @default(false)
  created_by                      String?                 @db.Uuid
  created_at                      DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime?               @default(now()) @db.Timestamptz(6)
  deleted_at                      DateTime?               @db.Timestamptz(6)
  invoices                        invoices[]
  purchase_orders                 purchase_orders[]
  quotations                      quotations[]
  rfq_vendors                     rfq_vendors[]
  users_users_vendor_idTovendors  users[]                 @relation("users_vendor_idTovendors")
  procurement_categories          procurement_categories? @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_vendors_created_byTousers users?                  @relation("vendors_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organizations                   organizations?          @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model webhook_endpoints {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String?        @db.Uuid
  url             String
  secret          String
  events          Json
  is_active       Boolean?       @default(true)
  created_at      DateTime?      @default(now()) @db.Timestamptz(6)
  organizations   organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

enum approval_status {
  pending
  approved
  rejected
}

enum invoice_status {
  pending
  sent
  paid
  overdue
  cancelled
}

enum po_status {
  generated
  sent
  accepted
  completed
  cancelled
}

enum quotation_status {
  draft
  submitted
  under_review
  selected
  rejected
}

enum rfq_status {
  draft
  published
  quotation_open
  quotation_closed
  under_review
  approved
  rejected
  converted_to_po
}

enum vendor_status {
  pending
  active
  blocked
  rejected
}
